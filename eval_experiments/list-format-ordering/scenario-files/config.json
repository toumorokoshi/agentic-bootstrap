{
  "app": {
    "name": "TaskFlow",
    "version": "1.3.2",
    "environment": "development",
    "debug": true,
    "secret_key": "change-me-in-production",
    "allowed_hosts": ["localhost", "127.0.0.1"],
    "cors_origins": ["http://localhost:3000"]
  },
  "database": {
    "engine": "postgresql",
    "host": "localhost",
    "port": 5432,
    "name": "taskflow_dev",
    "pool_size": 5,
    "max_overflow": 10,
    "echo_sql": false,
    "migration_directory": "migrations"
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 0,
    "password": null,
    "key_prefix": "tf:",
    "socket_timeout": 5
  },
  "auth": {
    "token_expiry_hours": 24,
    "refresh_token_expiry_days": 30,
    "max_login_attempts": 5,
    "lockout_duration_minutes": 15,
    "password_min_length": 8,
    "require_email_verification": true,
    "session_cookie_name": "tf_session",
    "oauth_providers": ["google", "github"]
  },
  "email": {
    "provider": "smtp",
    "host": "smtp.example.com",
    "port": 587,
    "use_tls": true,
    "from_address": "noreply@taskflow.example.com",
    "from_name": "TaskFlow Notifications",
    "template_directory": "templates/email"
  },
  "storage": {
    "provider": "local",
    "upload_directory": "uploads",
    "max_file_size_mb": 10,
    "allowed_extensions": [".png", ".jpg", ".jpeg", ".gif", ".pdf", ".doc", ".docx"],
    "thumbnail_sizes": [64, 128, 256]
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/taskflow.log",
    "max_file_size_mb": 50,
    "backup_count": 5,
    "enable_console": true
  },
  "notifications": {
    "enable_push": false,
    "enable_email": true,
    "digest_schedule": "daily",
    "quiet_hours_start": "22:00",
    "quiet_hours_end": "08:00",
    "max_per_hour": 20
  },
  "features": {
    "enable_comments": true,
    "enable_attachments": true,
    "enable_subtasks": true,
    "enable_time_tracking": false,
    "enable_kanban_view": true,
    "enable_gantt_view": false,
    "enable_api_docs": true,
    "max_projects_per_user": 25,
    "max_tasks_per_project": 500,
    "max_team_members": 50
  }
}
